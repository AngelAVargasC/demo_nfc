# ===========================================================================
#  BASE DE DATOS
# ===========================================================================
# OPCION A (recomendada): pega la URL completa que te dio el proveedor.
#   Se aceptan postgres://, postgresql:// y postgresql+asyncpg:// (se normaliza).
#   Ejemplos:
#     Railway   postgresql://postgres:PASS@HOST.proxy.rlwy.net:PUERTO/railway
#     Supabase  postgresql://postgres:PASS@db.REF.supabase.co:5432/postgres?sslmode=require
#     Neon      postgresql://USER:PASS@HOST.neon.tech/DB?sslmode=require
#     Render    postgresql://USER:PASS@HOST.oregon-postgres.render.com/DB
DATABASE_URL=postgresql://USUARIO:PASSWORD@HOST:5432/NOMBRE_DB

# OPCION B: deja DATABASE_URL vacio y rellena estas piezas en su lugar.
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_HOST=
# POSTGRES_PORT=5432
# POSTGRES_DB=

# SSL: si tu URL NO trae ?sslmode= y el proveedor exige conexion cifrada
# (Supabase, Neon, Render, etc.), pon esto en true.
POSTGRES_SSL=false

# Carga el seed demo (admin, logias, usuarios, NFC...) al arrancar.
# Dejalo en true para el PRIMER deploy; luego puedes ponerlo en false.
RUN_SEED=true

# Redis (opcional). Vacio => usa cache en memoria.
REDIS_URL=

# ===========================================================================
#  SEGURIDAD / APP
# ===========================================================================
SECRET_KEY=change-this-to-a-very-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ENVIRONMENT=production
DEBUG=false
CORS_ORIGINS=["http://localhost:5173"]
HASH_ALGORITHM=argon2
NFC_REPLAY_WINDOW_SECONDS=30

# ===========================================================================
#  RECONOCIMIENTO FACIAL (FaceID)
# ===========================================================================
# URL del servicio ML (carpeta faceid-service/) desplegado en Railway.
FACEID_SERVICE_URL=
# Debe coincidir con la variable API_KEY del servicio ML.
FACEID_API_KEY=
# Clave del kiosco de la puerta (endpoint face/identify).
KIOSK_API_KEY=
# Umbral de similitud coseno y margen para el match 1:N (calibrar en producción).
FACE_MATCH_THRESHOLD=0.40
FACE_MATCH_MARGIN=0.05
